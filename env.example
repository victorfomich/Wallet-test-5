# Конфигурация для DreamWallet v2

# === ОСНОВНОЙ Supabase (обязательно) ===
# Supabase → Project Settings → API
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-public-key-here
SUPABASE_SERVICE_KEY=your-service-role-key-here

# === ВТОРОЙ Supabase для seed-фраз (опционально) ===
# Можно использовать тот же проект: укажите те же URL и service_role key
VW_RUNTIME_DB_URL=https://your-project-ref.supabase.co
VW_RUNTIME_DB_SERVICE_KEY=your-service-role-key-here

# Пароль для админ-панели (обязательно на Vercel)
ADMIN_PASSWORD=change-me

# === Supabase для P2P-мерчантов бота (опционально) ===
# Если merchants в отдельном проекте — укажите URL и service_role key бота
# MERCHANTS_SUPABASE_URL=https://your-merchants-project.supabase.co
# MERCHANTS_SUPABASE_SERVICE_KEY=your-merchants-service-role-key

NODE_ENV=production
